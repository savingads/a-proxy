# Environment variables for a-proxy
# Copy this file to .env and fill in your values

# --- LLM Configuration ---
# Set LLM_PROVIDER to force a specific provider.
# If unset, auto-detects based on which credentials are configured.
# Options: openai_compatible, anthropic, openai
# LLM_PROVIDER=openai_compatible

# OpenAI-compatible endpoint (vLLM, Ollama, text-generation-webui, LiteLLM)
# This is the recommended setup for local/self-hosted models (e.g. Qwen on HPC)
# OPENAI_COMPATIBLE_URL=http://picotte-host:8000/v1
# OPENAI_COMPATIBLE_MODEL=Qwen/Qwen2.5-72B-Instruct
# OPENAI_COMPATIBLE_API_KEY=none

# Anthropic (Claude) — commercial, requires API key
# ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (GPT) — commercial, requires API key
# OPENAI_API_KEY=sk-YOUR_KEY_HERE
# OPENAI_MODEL=gpt-4o-mini

# Max output tokens for LLM responses
# LLM_MAX_OUTPUT_TOKENS=4096

# --- Flask ---
SECRET_KEY=your_flask_secret_key_here
DEBUG=True

# --- Proxy (optional, for geo-IP routing) ---
# PROXY_URL=socks5://user:pass@host:port

# --- Browser ---
# BROWSER_HEADLESS=True
