# Environment variables for a-proxy Docker deployment
# The default docker-compose.yml includes Ollama with Qwen 2.5 7B.
# No configuration is required for basic usage — just run: docker-compose up --build

# --- LLM Configuration ---
# Default: bundled Ollama service (no changes needed)
# The compose file sets OPENAI_COMPATIBLE_URL=http://ollama:11434/v1 automatically.

# To use a different model with the bundled Ollama, change this:
# OPENAI_COMPATIBLE_MODEL=qwen2.5:7b

# To use Drexel Picotte HPC instead of bundled Ollama:
# Requires: Drexel VPN connected + active vLLM SLURM job
# OPENAI_COMPATIBLE_URL=http://host.docker.internal:8000/v1
# OPENAI_COMPATIBLE_MODEL=Qwen/Qwen2.5-72B-Instruct

# To use a cloud API instead of local models:
# ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
# OPENAI_API_KEY=sk-YOUR_KEY_HERE

# --- Flask ---
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=false

# --- Proxy (optional, for geo-IP routing) ---
# PROXY_URL=socks5://user:pass@host:port
